# PatchOps Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env

# AI
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxx

# GitHub (classic PAT, repo scope)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# AWS
AWS_REGION=us-east-1
DYNAMODB_TABLE=patchops_pipeline
S3_BUCKET=patchops-artifacts

# EC2 Sandbox (Person A fills this in after EC2 is up)
SANDBOX_URL=http://PENDING_EC2_IP:8000
SANDBOX_TOKEN=patchops-secret-2024

# Groq Model
GROQ_MODEL=llama-3.1-8b-efficient

LAYER_ARN=arn:aws:lambda:eu-north-1:572540381020:layer:patchops-deps:1